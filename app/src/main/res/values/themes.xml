<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- No animations: every transition is a single e-ink redraw. -->
    <style name="Theme.Reader" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!-- Aa sheet controls: monochrome, large tap targets, no ripple/animation. A selected option is
         marked by a boxed outline background (aa_option_selected), set in code
         (ReaderActivity.setOptionSelected). The outline is a static drawable — no state list, so
         nothing animates (the e-ink constraint). Shared by the segmented options and the size
         stepper. -->
    <style name="AaOption">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:minWidth">56dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- A full-width toggle row: a static label on the left and a hand-drawn ToggleSwitchView on the
         right. The whole row is the tap target (it flips the pref); the switch is a pure display of
         the resulting boolean, set in ReaderActivity.refreshSheet. No ripple/animation. -->
    <style name="AaToggleRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingVertical">10dp</item>
    </style>

    <style name="AaToggleLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>
