<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- No animations: every transition is a single e-ink redraw.
         windowAnimationStyle kills Activity enter/exit, but it does not reach the *popup* windows
         AppCompat opens for the toolbar overflow, nor the ripple on toolbar items. Those are
         inherited from the parent theme and animate by default, so the library's overflow, search,
         sort/view/filter menus, and every toolbar back arrow were the one place the app still
         animated. Overridden below. -->
    <style name="Theme.Reader" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:popupMenuStyle">@style/Widget.Reader.PopupMenu</item>
        <item name="popupMenuStyle">@style/Widget.Reader.PopupMenu</item>
        <item name="android:popupWindowStyle">@style/Widget.Reader.PopupWindow</item>
        <item name="actionBarItemBackground">@android:color/transparent</item>
        <item name="selectableItemBackground">@android:color/transparent</item>
        <item name="selectableItemBackgroundBorderless">@android:color/transparent</item>
    </style>

    <!-- Popup menus open and close with no fade/scale: one redraw, not an animated sequence. -->
    <style name="Widget.Reader.PopupMenu" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupAnimationStyle">@null</item>
        <item name="android:popupEnterTransition">@null</item>
        <item name="android:popupExitTransition">@null</item>
    </style>

    <style name="Widget.Reader.PopupWindow" parent="Widget.AppCompat.PopupWindow">
        <item name="android:popupAnimationStyle">@null</item>
        <item name="android:popupEnterTransition">@null</item>
        <item name="android:popupExitTransition">@null</item>
    </style>

    <!-- Aa sheet controls: monochrome, large tap targets, no ripple/animation. A selected option is
         marked by a boxed outline background (aa_option_selected), set in code
         (ReaderActivity.setOptionSelected). The outline is a static drawable — no state list, so
         nothing animates (the e-ink constraint). Shared by the segmented options and the size
         stepper. -->
    <style name="AaOption">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:minWidth">56dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- A full-width toggle row: a static label on the left and a hand-drawn ToggleSwitchView on the
         right. The whole row is the tap target (it flips the pref); the switch is a pure display of
         the resulting boolean, set in ReaderActivity.refreshSheet. No ripple/animation. -->
    <style name="AaToggleRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingVertical">10dp</item>
    </style>

    <style name="AaToggleLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- The on-screen dismiss for every reader panel/sheet: a ✕ pinned to the top-right of the
         header, in one shared style so its glyph, size, and 48dp tap target are identical across the
         Contents, Bookmarks, Highlights, and Aa surfaces. The device has no hardware Back, so this is
         the only guaranteed way to close a panel; consistent placement lets the reader learn it once.
         Monochrome, no ripple/animation (the e-ink constraint). -->
    <style name="PanelClose">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:text">✕</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">20sp</item>
    </style>
</resources>
