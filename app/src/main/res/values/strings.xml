<?xml version="1.0" encoding="utf-8"?>
<!--
  Every user-facing string in the app.

  Error messages here are deliberately plain-language and carry no exception text. The raw
  throwable goes to Log.w with a tag, where it is useful to whoever is debugging; a reader who
  taps a damaged book should be told the book is damaged, not shown "error in opening zip file"
  or a bare "NullPointerException".
-->
