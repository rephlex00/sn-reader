<?xml version="1.0" encoding="utf-8"?>
<!-- The library grid's reading-progress badge: white fill, hairline black border, black text.
     NOT a black fill — the badge sits over unpredictable cover artwork, and white-with-border
     stays legible over any shade while matching the app's chrome idiom (white bars, black text,
     flat black rules). No gradient, no shadow: both ghost on e-ink. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/white" />
    <stroke
        android:width="1dp"
        android:color="@android:color/black" />
    <corners android:radius="3dp" />
</shape>
