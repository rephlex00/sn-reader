<?xml version="1.0" encoding="utf-8"?>
<!--
  Trash, not ✕. The row's delete control used to be the same ✕ glyph as the panel-header close
  button, at the same right margin, a little over a finger's width apart: a mis-tap destroyed a
  highlight instead of closing the panel, with no confirmation and no undo. A distinct shape is
  the fix; the two controls must never be mistaken for one another.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?android:attr/textColorPrimary">
    <path
        android:pathData="M6,19c0,1.1 0.9,2 2,2h8c1.1,0 2,-0.9 2,-2V7H6v12zM19,4h-3.5l-1,-1h-5l-1,1H5v2h14V4z"
        android:fillColor="#FF000000" />
</vector>
