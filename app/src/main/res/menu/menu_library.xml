<?xml version="1.0" encoding="utf-8"?>
<!-- Sorting is in SQL (BookDao.observeAllSorted) — this menu only selects the SortOrder;
     nothing here re-sorts a list in Kotlin.

     checkableBehavior="single" makes the group act as a radio selection: tapping an item checks
     it and unchecks its siblings automatically, so the active sort order has a visible mark
     on-screen (it didn't before). LibraryActivity.onCreate still has to set the initial check
     mark itself after inflating this menu — a freshly inflated menu (every rotation gets a new
     one) always starts with nothing checked, regardless of which SortOrder is actually active.

     The `header_*` items are disabled (non-clickable) section labels. This popup mixes two
     separate single-choice radio groups (sort, then view mode) plus a standalone toggle; without
     labels they read as one undifferentiated list and the two active radio marks look like one
     group. Disabled items render greyed and inert — LibraryActivity never sees them in
     onOptionsItemSelected — so they act purely as headings. -->
<menu xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <!-- Title/author search. The action view (an AppCompat SearchView, not a dialog) collapses
         back to just this icon on collapse; LibraryActivity clears searchQuery in both the
         onQueryTextChange and onMenuItemActionCollapse callbacks. ifRoom: shown as an icon when
         there's space, otherwise folded into the overflow like every other item here. -->
    <item
        android:id="@+id/action_search"
        android:icon="@android:drawable/ic_menu_search"
        android:title="@string/menu_search"
        app:showAsAction="ifRoom|collapseActionView"
        app:actionViewClass="androidx.appcompat.widget.SearchView" />
    <item
        android:id="@+id/header_sort"
        android:enabled="false"
        android:title="@string/menu_sort_by" />
    <group
        android:id="@+id/sort_group"
        android:checkableBehavior="single">
        <item
            android:id="@+id/sort_title"
            android:title="@string/menu_sort_title" />
        <item
            android:id="@+id/sort_author"
            android:title="@string/menu_sort_author" />
        <item
            android:id="@+id/sort_recently_added"
            android:title="@string/menu_sort_recently_added" />
        <item
            android:id="@+id/sort_recently_opened"
            android:title="@string/menu_sort_recently_opened" />
    </group>
    <!-- The tiles/list toggle, styled like the sort group: checkableBehavior="single" makes the
         two items a radio pair so the active view mode carries a visible mark. LibraryActivity
         sets the initial check after inflating (a freshly inflated menu — every rotation gets one
         — starts with nothing checked, regardless of the persisted ViewMode). -->
    <item
        android:id="@+id/header_view"
        android:enabled="false"
        android:title="@string/menu_view" />
    <group
        android:id="@+id/view_group"
        android:checkableBehavior="single">
        <item
            android:id="@+id/view_tiles"
            android:title="@string/menu_view_tiles" />
        <item
            android:id="@+id/view_list"
            android:title="@string/menu_view_list" />
    </group>
    <!-- A standalone checkable toggle (not a radio group): flatten collapses the folder tree to
         every book under the root. LibraryActivity restores its check state after inflating, the
         same way it does for the sort and view-mode marks. -->
    <item
        android:id="@+id/action_flatten"
        android:checkable="true"
        android:title="@string/menu_flatten_folders" />
    <!-- Reading-status filter, styled exactly like the sort/view groups above: a disabled header
         label plus a single-choice radio group. Selecting anything but "All" (together with a
         non-blank search query) switches the library to LibraryActivity's flat filtered-results
         branch instead of the folder listing; see isFilterActive/findBooks. -->
    <item
        android:id="@+id/header_filter"
        android:enabled="false"
        android:title="@string/menu_filter" />
    <group
        android:id="@+id/filter_group"
        android:checkableBehavior="single">
        <item
            android:id="@+id/filter_all"
            android:title="@string/filter_all" />
        <item
            android:id="@+id/filter_not_started"
            android:title="@string/filter_not_started" />
        <item
            android:id="@+id/filter_in_progress"
            android:title="@string/filter_in_progress" />
        <item
            android:id="@+id/filter_finished"
            android:title="@string/filter_finished" />
    </group>
    <!-- Outside every checkable group: this is an action, not a selection, so it must not carry a
         check mark. Opens SettingsActivity. -->
    <item
        android:id="@+id/action_settings"
        android:title="@string/menu_settings" />
</menu>
