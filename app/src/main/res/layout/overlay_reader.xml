<?xml version="1.0" encoding="utf-8"?>
<!-- The reading overlay: a monochrome chrome layer drawn ABOVE the page (added after PageView in
     the content FrameLayout). The top bar holds Back, the book title, and the Contents (TOC) and
     Aa (typography) buttons; a read-only page scrubber sits at the bottom. The Contents list and
     the Aa sheet are separate visibility-toggled panels inside this overlay.

     Touch model: this root FrameLayout is NOT clickable, so it does not consume touches — only its
     Back control does. A tap anywhere else on the overlay falls through to the PageView below, whose
     onTap sees the overlay is up and dismisses it (one redraw) instead of turning a page. See
     ReaderActivity.onTap. Starts GONE; ReaderActivity toggles visibility. No background on the root,
     so the page shows through between the two opaque-white bars.

     e-ink: solid white bars, black text, flat black divider lines. No ripple/selectableItemBackground
     (it animates), no elevation/shadow (it ghosts), no animation of any kind. Large tap targets. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reader_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone">

    <!-- Top bar: Back + book title, anchored to the top edge. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@android:color/white"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="‹ Back"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/book_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingHorizontal="8dp"
                android:paddingVertical="12dp"
                android:textColor="@android:color/black"
                android:textSize="18sp" />

            <!-- Opens the table-of-contents panel. Like Back, the only clickable thing in its own
                 footprint, so it consumes its own tap while page-area taps fall through to dismiss. -->
            <TextView
                android:id="@+id/contents_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="12dp"
                android:text="Contents"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Opens the typography sheet below. Like Back, it is the only clickable thing on its
                 row, so it consumes its own tap while page-area taps fall through to dismiss. -->
            <TextView
                android:id="@+id/settings_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="Aa"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@android:color/black" />

    </LinearLayout>

    <!-- Bottom scrubber: read-only "page X of Y" readout, anchored to the bottom edge. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/white"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@android:color/black" />

        <TextView
            android:id="@+id/scrubber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:textColor="@android:color/black"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- The Aa typography sheet: a bottom-anchored panel of monochrome controls, opened by the Aa
         button and toggled by visibility (one e-ink redraw, no animation). It is clickable=true so
         a tap on its own chrome is consumed rather than falling through to dismiss the overlay; the
         Aa button toggles it. Each control writes a ReaderPrefs field, rebuilds the RenderConfig and
         live-re-paginates the current chapter, keeping the reader on the same text (see
         ReaderActivity.applySettingsChange). Starts GONE. Drawn last, so it sits above the scrubber
         it covers while open. -->
    <ScrollView
        android:id="@+id/settings_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/white"
        android:clickable="true"
        android:focusable="true"
        android:fillViewport="false"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginBottom="8dp"
                android:background="@android:color/black" />

            <!-- Font family -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Font"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <!-- Each option is shown in its own face (set in ReaderActivity), so the picker
                     previews the fonts before selection. -->
                <TextView
                    android:id="@+id/font_literata"
                    style="@style/AaOption"
                    android:text="Literata" />

                <TextView
                    android:id="@+id/font_bitter"
                    style="@style/AaOption"
                    android:text="Bitter" />

                <TextView
                    android:id="@+id/font_atkinson"
                    style="@style/AaOption"
                    android:text="Atkinson" />
            </LinearLayout>

            <!-- Text size stepper -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Text size"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/size_minus"
                    style="@style/AaOption"
                    android:text="A −" />

                <TextView
                    android:id="@+id/size_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="64dp"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/size_plus"
                    style="@style/AaOption"
                    android:text="A +" />
            </LinearLayout>

            <!-- Line spacing -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Line spacing"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/spacing_12"
                    style="@style/AaOption"
                    android:text="1.2" />

                <TextView
                    android:id="@+id/spacing_14"
                    style="@style/AaOption"
                    android:text="1.4" />

                <TextView
                    android:id="@+id/spacing_16"
                    style="@style/AaOption"
                    android:text="1.6" />
            </LinearLayout>

            <!-- Margins -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Margins"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/margin_narrow"
                    style="@style/AaOption"
                    android:text="Narrow" />

                <TextView
                    android:id="@+id/margin_medium"
                    style="@style/AaOption"
                    android:text="Medium" />

                <TextView
                    android:id="@+id/margin_wide"
                    style="@style/AaOption"
                    android:text="Wide" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="6dp"
                android:background="@android:color/black" />

            <!-- Toggles: a static label + a hand-drawn switch; the whole row flips the pref on tap
                 and refreshSheet sets each switch's checked state. -->
            <LinearLayout
                android:id="@+id/toggle_justify"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="Justify" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_justify_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toggle_hyphen"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="Hyphenation" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_hyphen_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toggle_publisher"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="Publisher styling" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_publisher_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toggle_headings"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="Heading detection" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_headings_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toggle_progress"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="Progress bar" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_progress_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- The table-of-contents panel: a full-height monochrome list of the book's already-parsed
         chapters (doc.toc), opened by the Contents button and toggled by visibility (one e-ink
         redraw, no animation). It is clickable=true so a tap on its own chrome is consumed rather
         than falling through to dismiss the overlay. Tapping an entry jumps the reader to that
         chapter/anchor via the same restore machinery the open path uses (see
         ReaderActivity.jumpToToc). Starts GONE. Drawn last, so it covers the bars while open; Back
         peels it off first (TOC -> overlay -> book). An empty/malformed TOC shows the "No contents"
         state (toc_empty) with the list hidden. -->
    <LinearLayout
        android:id="@+id/toc_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:text="Contents"
            android:textColor="@android:color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@android:color/black" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/toc_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical" />

        <!-- Shown (with toc_list hidden) when the book has no usable TOC — never an empty clickable
             void. Unreachable for a well-formed EPUB, since the parser synthesizes a flat spine TOC
             when neither nav nor NCX is present, but the reader must still degrade gracefully. -->
        <TextView
            android:id="@+id/toc_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="24dp"
            android:text="No contents"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
