<?xml version="1.0" encoding="utf-8"?>
<!-- The reading overlay: a monochrome chrome layer drawn ABOVE the page (added after PageView in
     the content FrameLayout). The top bar holds Back, the book title, and the Contents (TOC) and
     Aa (typography) buttons; a read-only page scrubber sits at the bottom. The Contents list and
     the Aa sheet are separate visibility-toggled panels inside this overlay.

     Touch model: this root FrameLayout is NOT clickable, so it does not consume touches — only its
     Back control does. A tap anywhere else on the overlay falls through to the PageView below, whose
     onTap sees the overlay is up and dismisses it (one redraw) instead of turning a page. See
     ReaderActivity.onTap. Starts GONE; ReaderActivity toggles visibility. No background on the root,
     so the page shows through between the two opaque-white bars.

     e-ink: solid white bars, black text, flat black divider lines. No ripple/selectableItemBackground
     (it animates), no elevation/shadow (it ghosts), no animation of any kind. Large tap targets. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reader_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone">

    <!-- Top bar: Back + book title, anchored to the top edge. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@android:color/white"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="@string/reader_back"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/book_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingHorizontal="@dimen/toolbar_button_padding_h"
                android:paddingVertical="@dimen/toolbar_padding_v"
                android:textColor="@android:color/black"
                android:textSize="18sp" />

            <!-- Opens the Bookmarks panel. Like Back, the only clickable thing in its own footprint,
                 so it consumes its own tap while page-area taps fall through to dismiss.
                 A glyph rather than a word: the label used to read "Marks" while the panel it opens
                 is titled "Bookmarks" and its action reads "Bookmark this page", so one feature wore
                 three names. The bookmark shape needs no label to be read. -->
            <ImageView
                android:id="@+id/bookmarks_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_bookmark"
                android:contentDescription="@string/reader_bookmarks" />

            <!-- Opens the Highlights panel. Like Back, the only clickable thing in its own footprint,
                 so it consumes its own tap while page-area taps fall through to dismiss. -->
            <TextView
                android:id="@+id/highlights_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="12dp"
                android:text="@string/reader_highlights"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Opens the table-of-contents panel. Like Back, the only clickable thing in its own
                 footprint, so it consumes its own tap while page-area taps fall through to dismiss. -->
            <TextView
                android:id="@+id/contents_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="12dp"
                android:text="@string/reader_contents"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Opens the typography sheet below. Like Back, it is the only clickable thing on its
                 row, so it consumes its own tap while page-area taps fall through to dismiss. -->
            <TextView
                android:id="@+id/settings_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:text="@string/reader_display_short"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@android:color/black" />

    </LinearLayout>

    <!-- Bottom scrubber: read-only "page X of Y" readout, anchored to the bottom edge. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/white"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@android:color/black" />

        <TextView
            android:id="@+id/scrubber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:textColor="@android:color/black"
            android:textSize="16sp" />

        <dev.reader.ui.ChapterScrubberView
            android:id="@+id/chapter_scrubber"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:paddingHorizontal="16dp" />

    </LinearLayout>

    <!-- The Aa typography sheet: a bottom-anchored panel of monochrome controls, opened by the Aa
         button and toggled by visibility (one e-ink redraw, no animation). It is clickable=true so
         a tap on its own chrome is consumed rather than falling through to dismiss the overlay; the
         Aa button toggles it. Each control writes a ReaderPrefs field, rebuilds the RenderConfig and
         live-re-paginates the current chapter, keeping the reader on the same text (see
         ReaderActivity.applySettingsChange). Starts GONE. Drawn last, so it sits above the scrubber
         it covers while open. -->
    <ScrollView
        android:id="@+id/settings_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/white"
        android:clickable="true"
        android:focusable="true"
        android:overScrollMode="never"
        android:fillViewport="false"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <!-- Header row: title + a top-right ✕ that closes the sheet (back to the reading toolbar),
                 matching the Contents/Bookmarks/Highlights panels so the dismiss is in one place. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingVertical="@dimen/panel_header_padding_v"
                    android:text="@string/reader_display"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/settings_close"
                    style="@style/PanelClose"
                    android:contentDescription="@string/panel_close_display" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/panel_divider_height"
                android:background="@android:color/black" />

            <!-- Font family -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_font"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <!-- Each option is shown in its own face (set in ReaderActivity), so the picker
                     previews the fonts before selection. -->
                <TextView
                    android:id="@+id/font_literata"
                    style="@style/AaOption"
                    android:text="@string/font_literata" />

                <TextView
                    android:id="@+id/font_bitter"
                    style="@style/AaOption"
                    android:text="@string/font_bitter" />

                <TextView
                    android:id="@+id/font_atkinson"
                    style="@style/AaOption"
                    android:text="@string/font_atkinson" />
            </LinearLayout>

            <!-- Text size stepper -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_text_size"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/size_minus"
                    style="@style/AaOption"
                    android:text="@string/text_size_decrease" />

                <TextView
                    android:id="@+id/size_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="64dp"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/size_plus"
                    style="@style/AaOption"
                    android:text="@string/text_size_increase" />
            </LinearLayout>

            <!-- Line spacing -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_line_spacing"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/spacing_12"
                    style="@style/AaOption"
                    android:text="@string/spacing_12" />

                <TextView
                    android:id="@+id/spacing_14"
                    style="@style/AaOption"
                    android:text="@string/spacing_14" />

                <TextView
                    android:id="@+id/spacing_16"
                    style="@style/AaOption"
                    android:text="@string/spacing_16" />
            </LinearLayout>

            <!-- Margins -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_margins"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/margin_narrow"
                    style="@style/AaOption"
                    android:text="@string/margin_narrow" />

                <TextView
                    android:id="@+id/margin_medium"
                    style="@style/AaOption"
                    android:text="@string/margin_medium" />

                <TextView
                    android:id="@+id/margin_wide"
                    style="@style/AaOption"
                    android:text="@string/margin_wide" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="6dp"
                android:background="@android:color/black" />

            <!-- Toggles: a static label + a hand-drawn switch; the whole row flips the pref on tap
                 and refreshSheet sets each switch's checked state. -->
            <LinearLayout
                android:id="@+id/toggle_justify"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="@string/setting_justify" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_justify_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toggle_hyphen"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="@string/setting_hyphenation" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_hyphen_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toggle_publisher"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="@string/setting_publisher_styling" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_publisher_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toggle_headings"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="@string/setting_heading_detection" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_headings_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toggle_progress"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="@string/setting_progress_bar" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_progress_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toggle_rotation_lock"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="@string/setting_rotation_lock" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_rotation_lock_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toggle_faster_turns"
                style="@style/AaToggleRow">
                <TextView style="@style/AaToggleLabel" android:text="@string/setting_faster_page_turns" />
                <dev.reader.ui.ToggleSwitchView android:id="@+id/toggle_faster_turns_switch"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Shown only when Faster page turns is ON: how many pages between full clean refreshes. -->
            <LinearLayout
                android:id="@+id/refresh_frequency_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_full_refresh_every"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <TextView android:id="@+id/refresh_freq_3" style="@style/AaOption" android:text="@string/refresh_every_3" />
                <TextView android:id="@+id/refresh_freq_6" style="@style/AaOption" android:text="@string/refresh_every_6" />
                <TextView android:id="@+id/refresh_freq_10" style="@style/AaOption" android:text="@string/refresh_every_10" />
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- The table-of-contents panel: a full-height monochrome list of the book's already-parsed
         chapters (doc.toc), opened by the Contents button and toggled by visibility (one e-ink
         redraw, no animation). It is clickable=true so a tap on its own chrome is consumed rather
         than falling through to dismiss the overlay. Tapping an entry jumps the reader to that
         chapter/anchor via the same restore machinery the open path uses (see
         ReaderActivity.jumpToToc). Starts GONE. Drawn last, so it covers the bars while open; Back
         peels it off first (TOC -> overlay -> book). An empty/malformed TOC shows the "No contents"
         state (toc_empty) with the list hidden. -->
    <LinearLayout
        android:id="@+id/toc_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Header row: title + a top-right ✕ that closes this panel (back to the reading toolbar).
             The device has no hardware Back, so every panel carries its own on-screen dismiss. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Letterspaced, uppercased and set at 14sp — a printed contents page's own head —
                 rather than the plain 20sp the other panels' headers use: this panel is styled as
                 the book's own contents page, not as another chrome sheet. One heading, one rule:
                 there used to be a second letterspaced "CONTENTS" head inserted below this one; it
                 duplicated this label and pushed a long entry's percentage out of view underneath,
                 so it was removed rather than kept alongside this one. -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:letterSpacing="0.18"
                android:paddingHorizontal="16dp"
                android:paddingVertical="@dimen/panel_header_padding_v"
                android:text="@string/reader_contents"
                android:textAllCaps="true"
                android:textColor="@android:color/black"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/toc_close"
                style="@style/PanelClose"
                android:contentDescription="@string/panel_close_contents" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@android:color/black" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/toc_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical" />

        <!-- Shown (with toc_list hidden) when the book has no usable TOC — never an empty clickable
             void. Unreachable for a well-formed EPUB, since the parser synthesizes a flat spine TOC
             when neither nav nor NCX is present, but the reader must still degrade gracefully. -->
        <LinearLayout
            android:id="@+id/toc_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contents_empty"
                android:textColor="@color/reader_text_primary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/contents_empty_hint"
                android:textColor="@color/reader_text_secondary"
                android:textSize="@dimen/text_meta" />

        </LinearLayout>

    </LinearLayout>

    <!-- The bookmarks panel: an "Add/remove this page" toggle, then the book's bookmarks (chapter ·
         %, tap to jump, ✕ to delete). Visibility-toggled like the Contents panel; one e-ink redraw,
         no animation. clickable=true so a tap on its own chrome is consumed, not fallen through to
         dismiss the overlay. -->
    <LinearLayout
        android:id="@+id/bookmarks_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Header row: title + a top-right ✕ that closes this panel (back to the reading toolbar). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingHorizontal="16dp"
                android:paddingVertical="@dimen/panel_header_padding_v"
                android:text="@string/reader_bookmarks"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bookmarks_close"
                style="@style/PanelClose"
                android:contentDescription="@string/panel_close_bookmarks" />

        </LinearLayout>

        <TextView
            android:id="@+id/bookmark_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:textColor="@android:color/black"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@android:color/black" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/bookmarks_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical" />

        <LinearLayout
            android:id="@+id/bookmarks_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bookmarks_empty"
                android:textColor="@color/reader_text_primary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/bookmarks_empty_hint"
                android:textColor="@color/reader_text_secondary"
                android:textSize="@dimen/text_meta" />

        </LinearLayout>

    </LinearLayout>

    <!-- The highlights panel: the book's highlights (excerpt, chapter · %, tap to jump, ✕ to delete).
         Unlike the bookmarks panel it has NO add/remove toggle — highlighting happens on the page with
         the pen, not from here. Visibility-toggled like the Contents/Bookmarks panels; one e-ink
         redraw, no animation. clickable=true so a tap on its own chrome is consumed, not fallen
         through to dismiss the overlay. -->
    <LinearLayout
        android:id="@+id/highlights_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Header row: title + a top-right ✕ that closes this panel (back to the reading toolbar). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/highlights_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingHorizontal="16dp"
                android:paddingVertical="@dimen/panel_header_padding_v"
                android:text="@string/reader_highlights"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/highlights_close"
                style="@style/PanelClose"
                android:contentDescription="@string/panel_close_highlights" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@android:color/black" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/highlights_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical" />

        <LinearLayout
            android:id="@+id/highlights_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="top|center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/highlights_empty"
                android:textColor="@color/reader_text_primary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/highlights_empty_hint"
                android:textColor="@color/reader_text_secondary"
                android:textSize="@dimen/text_meta" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
