<?xml version="1.0" encoding="utf-8"?>
<!-- One highlight row: a two-line body that fills the width (excerpt over chapter·%, tap to jump)
     and a trailing ✕ (tap to delete). Monochrome, large tap targets, no ripple/animation. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <LinearLayout
        android:id="@+id/highlight_body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="48dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/highlight_excerpt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="@android:color/black"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/highlight_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:textColor="#666666"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/highlight_delete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:paddingHorizontal="16dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_delete"
        android:contentDescription="@string/highlight_delete" />

</LinearLayout>
