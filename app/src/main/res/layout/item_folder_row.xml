<?xml version="1.0" encoding="utf-8"?>
<!-- A folder as a single full-width list row: name + recursive book count, with the same drawn
     ">" glyph as the tile so folders read as folders in both modes. No image asset, black on
     white. No animation-bearing attributes; itemAnimator = null (see LibraryActivity). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="16dp">

    <TextView
        android:id="@+id/folder_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
