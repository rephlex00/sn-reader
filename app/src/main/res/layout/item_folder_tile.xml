<?xml version="1.0" encoding="utf-8"?>
<!-- A folder cell in tile mode: a full-span row above the book covers (GridLayoutManager's
     spanSizeLookup makes it span every column). No image asset — an e-ink-crisp drawn glyph in
     the text itself ("> name (count)"), black on white. No animation-bearing attributes; the
     RecyclerView additionally runs with itemAnimator = null (see LibraryActivity). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp">

    <TextView
        android:id="@+id/folder_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
