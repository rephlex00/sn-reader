<?xml version="1.0" encoding="utf-8"?>
<!-- One bookmark row: a label that fills the width (tap to jump) and a trailing ✕ (tap to delete).
     Monochrome, large tap targets, no ripple/animation. Black on white, e-ink-crisp. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/bookmark_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:textColor="@android:color/black"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/bookmark_delete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:text="✕"
        android:textColor="@android:color/black"
        android:textSize="18sp" />

</LinearLayout>
